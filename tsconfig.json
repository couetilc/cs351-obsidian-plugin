{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"lib": ["DOM", "ES2020"],
		"strict": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
